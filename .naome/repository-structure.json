{
  "schema": "naome.repository-structure.v1",
  "version": 1,
  "status": "ready",
  "enabledAdapters": [
    "ios-app-structure",
    "ios-resources",
    "javascript-typescript",
    "swift",
    "swift-package",
    "swiftui",
    "xcode",
    "xctest"
  ],
  "sourceRoots": [
    "src/**",
    "app/**",
    "apps/*/src/**",
    "packages/*/src/**",
    "crates/*/src/**",
    "**/src/**",
    "lib/**"
  ],
  "testRoots": [
    "test/**",
    "tests/**",
    "__tests__/**",
    "packages/*/test/**",
    "packages/*/tests/**",
    "crates/*/tests/**",
    "**/tests/**",
    "scripts/*.test.js"
  ],
  "docsRoots": [
    "docs/**",
    "doc/**"
  ],
  "generatedRoots": [
    "**/generated/**",
    "**/__generated__/**",
    "**/codegen/**",
    "**/*.generated.*"
  ],
  "artifactRoots": [
    "dist/**",
    "build/**",
    "coverage/**",
    ".next/**",
    "target/**",
    "**/dist/**",
    "**/build/**"
  ],
  "moduleRoots": [
    "src/**",
    "app/**",
    "packages/*/src/**",
    "crates/*/src/**",
    "**/src/**"
  ],
  "allowedRootFiles": [
    "README.md",
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "AGENTS.md",
    "package.json",
    "package-lock.json",
    "Cargo.toml",
    "pyproject.toml",
    "go.mod",
    "go.sum",
    "Makefile",
    ".gitignore",
    ".naomeignore"
  ],
  "directoryRoleRules": [],
  "layerRules": [],
  "ignoredPaths": [
    ".git/**",
    "node_modules/**",
    "vendor/**",
    "target/**",
    "**/target/**",
    "dist/**",
    "build/**",
    "coverage/**",
    ".next/**"
  ],
  "disabledChecks": [],
  "changedCodePolicy": "block",
  "debtPolicy": "report",
  "limits": {
    "maxDirectoryFiles": 40,
    "maxPathDepth": 10,
    "maxDirectoryRoles": 2,
    "maxDumpingGroundFiles": 12
  }
}
