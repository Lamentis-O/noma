{
  "schema": "naome.ui-contract.v1",
  "version": 1,
  "optOut": {
    "platformProfiles": []
  },
  "platformProfiles": [
    {
      "id": "ios-swiftui",
      "fileGlobs": ["Noma/**/*.swift"],
      "tokens": {
        "textStyles": [
          { "id": "typography.title", "swiftui": ".title" },
          { "id": "typography.title3", "swiftui": ".title3" },
          { "id": "typography.headline", "swiftui": ".headline" },
          { "id": "typography.subheadline", "swiftui": ".subheadline" },
          { "id": "typography.body", "swiftui": ".body" }
        ],
        "spacing": [
          { "id": "spacing.xs", "value": 4, "swiftui": "NomaSpacing.xs" },
          { "id": "spacing.sm", "value": 8, "swiftui": "NomaSpacing.sm" },
          { "id": "spacing.md", "value": 12, "swiftui": "NomaSpacing.md" },
          { "id": "spacing.lg", "value": 16, "swiftui": "NomaSpacing.lg" },
          { "id": "spacing.xl", "value": 24, "swiftui": "NomaSpacing.xl" },
          { "id": "spacing.xxl", "value": 32, "swiftui": "NomaSpacing.xxl" },
          { "id": "size.scrollDismissSentinel", "value": 1, "swiftui": "NomaSize.scrollDismissSentinel" },
          { "id": "size.sendButton", "value": 34, "swiftui": "NomaSize.sendButton" },
          { "id": "size.taskDeleteSwipeThreshold", "value": 72, "swiftui": "NomaSize.taskDeleteSwipeThreshold" }
        ],
        "offsets": [
          { "id": "offset.keyboardAccessoryOverlap", "value": -20, "swiftui": "NomaOffset.keyboardAccessoryOverlap" }
        ],
        "radius": [
          { "id": "radius.composer", "value": 25, "swiftui": "NomaRadius.composer" }
        ],
        "colors": [
          { "id": "color.text.primary", "swiftui": ".textPrimary" },
          { "id": "color.text.secondary", "swiftui": ".textSecondary" },
          { "id": "color.text.primaryBackground", "swiftui": ".primaryBackground" },
          { "id": "color.background.primary", "swiftui": ".primaryBackground" },
          { "id": "color.control.active", "swiftui": ".controlActive" },
          { "id": "color.control.error", "swiftui": ".controlError" },
          { "id": "color.control.success", "swiftui": ".controlSuccess" }
        ]
      },
      "components": [
        {
          "id": "component.primary-button",
          "name": "PrimaryButton",
          "swiftuiType": "PrimaryButton",
          "adHocPatterns": ["Capsule().fill"],
          "severity": "warning"
        },
        {
          "id": "component.primary-glass-button",
          "name": "PrimaryGlassButton",
          "swiftuiType": "PrimaryGlassButton",
          "adHocPatterns": [".buttonStyle(.glassProminent)"],
          "severity": "warning"
        },
        {
          "id": "component.sign-in-with-apple-glass-button",
          "name": "SignInWithAppleGlassButton",
          "swiftuiType": "SignInWithAppleGlassButton",
          "adHocPatterns": ["Image(systemName: \"apple.logo\")"],
          "severity": "warning"
        },
        {
          "id": "component.reminder-input-bar",
          "name": "ReminderInputBar",
          "swiftuiType": "ReminderInputBar",
          "adHocPatterns": ["TextField("],
          "severity": "warning"
        },
        {
          "id": "component.hint-view",
          "name": "HintView",
          "swiftuiType": "HintView",
          "adHocPatterns": [".font(.title.weight(.bold))"],
          "severity": "warning"
        }
      ],
      "rules": [
        { "id": "ios-swiftui.no-hardcoded-system-font", "severity": "error" },
        {
          "id": "ios-swiftui.no-magic-spacing",
          "severity": "error",
          "allowedLiterals": [
            { "value": 0, "contexts": [".padding", ".safeAreaPadding", ".frame", ".offset", ".cornerRadius", ".contentMargins", ".safeAreaInset", "spacing", "CGFloat"] },
            { "value": 1, "contexts": ["geometry-sentinel", "separator", "scaleEffect"] },
            { "value": 1.5, "contexts": ["NomaScale", "CGFloat"] },
            { "value": 0.96, "contexts": ["NomaScale", "CGFloat"] }
          ]
        },
        { "id": "ios-swiftui.no-direct-color", "severity": "warning" },
        { "id": "ios-swiftui.prefer-registered-component", "severity": "warning" }
      ]
    }
  ]
}
