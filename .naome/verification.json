{
  "schema": "naome.verification.v1",
  "version": 1,
  "status": "ready",
  "lastUpdated": "2026-05-15",
  "checks": [
    {
      "id": "npm-install",
      "command": "npm install",
      "cwd": ".",
      "purpose": "Install and verify repository npm dependencies from the committed lockfile.",
      "cost": "fast",
      "source": "package.json and package-lock.json",
      "evidence": [
        "package.json",
        "package-lock.json"
      ],
      "lastVerified": "2026-05-15"
    },
    {
      "id": "xcode-list",
      "command": "xcodebuild -list -project Noma.xcodeproj",
      "cwd": ".",
      "purpose": "Verify the Xcode project exposes the expected targets and scheme.",
      "cost": "fast",
      "source": "Xcode project intake",
      "evidence": [
        "Noma.xcodeproj/project.pbxproj"
      ],
      "lastVerified": "2026-05-15"
    },
    {
      "id": "xcode-build-ios-simulator",
      "command": "xcodebuild -project Noma.xcodeproj -scheme Noma -destination 'platform=iOS Simulator,id=E394FB54-CFA1-4765-B2FE-B7A90FE4A0AA' -derivedDataPath /private/tmp/noma-derived-data build",
      "cwd": ".",
      "purpose": "Compile the Noma iOS app for the iOS Simulator.",
      "cost": "medium",
      "source": "Xcode project intake",
      "evidence": [
        "Noma.xcodeproj/project.pbxproj",
        "Noma/NomaApp.swift",
        "Noma/ContentView.swift"
      ],
      "lastVerified": "2026-05-15"
    },
    {
      "id": "xcode-test-iphone-17-pro",
      "command": "xcodebuild test -project Noma.xcodeproj -scheme Noma -destination 'platform=iOS Simulator,id=E394FB54-CFA1-4765-B2FE-B7A90FE4A0AA' -derivedDataPath /private/tmp/noma-derived-data",
      "cwd": ".",
      "purpose": "Run unit and UI tests on the latest available iPhone 17 Pro simulator.",
      "cost": "medium",
      "source": "User-confirmed default simulator",
      "evidence": [
        "Noma.xcodeproj/project.pbxproj",
        "NomaTests/NomaTests.swift",
        "NomaUITests/NomaUITests.swift"
      ],
      "lastVerified": null
    },
    {
      "id": "diff-check",
      "command": "git diff --check",
      "cwd": ".",
      "purpose": "Reject whitespace errors in the current diff.",
      "cost": "fast",
      "source": "NAOME built-in",
      "evidence": [],
      "lastVerified": null
    },
    {
      "id": "naome-harness-health",
      "command": "node .naome/bin/check-harness-health.js",
      "cwd": ".",
      "purpose": "Validate the installed NAOME harness before feature work or task completion.",
      "cost": "fast",
      "source": "NAOME built-in",
      "evidence": [
        ".naome/bin/check-harness-health.js"
      ],
      "lastVerified": "2026-05-15"
    },
    {
      "id": "naome-task-state",
      "command": "node .naome/bin/check-task-state.js",
      "cwd": ".",
      "purpose": "Validate the NAOME task-state contract for the current repository.",
      "cost": "fast",
      "source": "NAOME built-in",
      "evidence": [
        ".naome/bin/check-task-state.js",
        ".naome/task-contract.schema.json"
      ],
      "lastVerified": null
    },
    {
      "id": "repository-quality-check",
      "command": "node .naome/bin/naome.js quality check --changed",
      "cwd": ".",
      "purpose": "Validate changed files against deterministic NAOME repository quality rules.",
      "cost": "fast",
      "source": "NAOME built-in",
      "evidence": [
        ".naome/repository-quality.json",
        ".naome/repository-structure.json",
        ".naome/repository-quality-baseline.json"
      ],
      "lastVerified": null
    },
    {
      "id": "repository-semantic-check",
      "command": "node .naome/bin/naome.js semantic check --changed",
      "cwd": ".",
      "purpose": "Validate changed files against deterministic NAOME semantic cleanup rules.",
      "cost": "fast",
      "source": "NAOME built-in",
      "evidence": [
        ".naome/repository-quality.json",
        ".naome/repository-quality-baseline.json"
      ],
      "lastVerified": null
    },
    {
      "id": "ui-style-check",
      "command": "node .naome/bin/naome.js ui check --changed --json",
      "cwd": ".",
      "purpose": "Validate changed SwiftUI files against the NAOME UI contract.",
      "cost": "fast",
      "source": "NAOME built-in",
      "evidence": [
        ".naome/ui-contract.json"
      ],
      "lastVerified": null
    },
    {
      "id": "architecture-fitness-check",
      "command": "node .naome/bin/naome.js arch validate --changed-only",
      "cwd": ".",
      "purpose": "Validate changed files against deterministic NAOME architecture fitness rules.",
      "cost": "fast",
      "source": "NAOME built-in",
      "evidence": [
        "docs/naome/architecture-fitness.md"
      ],
      "lastVerified": null
    }
  ],
  "phases": [
    {
      "id": "shape-health",
      "order": 10,
      "checkIds": [
        "naome-harness-health",
        "naome-task-state"
      ]
    },
    {
      "id": "quality",
      "order": 20,
      "checkIds": [
        "repository-quality-check",
        "repository-semantic-check",
        "ui-style-check",
        "architecture-fitness-check"
      ]
    },
    {
      "id": "focused-tests",
      "order": 30,
      "checkIds": [
        "npm-install",
        "xcode-list",
        "xcode-build-ios-simulator",
        "xcode-test-iphone-17-pro"
      ]
    },
    {
      "id": "diff-check",
      "order": 60,
      "checkIds": [
        "diff-check"
      ]
    }
  ],
  "changeTypes": [
    {
      "id": "ios-app-source",
      "description": "SwiftUI app source or asset changes.",
      "paths": [
        "Noma/**/*.swift",
        "Noma/Assets.xcassets/**"
      ],
      "requiredChecks": [
        "xcode-build-ios-simulator",
        "xcode-test-iphone-17-pro",
        "repository-quality-check",
        "repository-semantic-check",
        "ui-style-check",
        "architecture-fitness-check",
        "diff-check"
      ],
      "recommendedChecks": [],
      "humanReview": false
    },
    {
      "id": "ios-tests",
      "description": "Unit-test or UI-test source changes.",
      "paths": [
        "NomaTests/**/*.swift",
        "NomaUITests/**/*.swift"
      ],
      "requiredChecks": [
        "xcode-build-ios-simulator",
        "repository-quality-check",
        "repository-semantic-check",
        "architecture-fitness-check",
        "diff-check"
      ],
      "recommendedChecks": [],
      "humanReview": true
    },
    {
      "id": "ai-subscription-payments",
      "description": "OpenAI API integration, API usage tracking, subscription/payment flows, or premium entitlement logic.",
      "paths": [
        "**/*OpenAI*",
        "**/*AI*",
        "**/*Subscription*",
        "**/*Payment*",
        "**/*Entitlement*",
        "**/*Premium*",
        "**/*Usage*"
      ],
      "requiredChecks": [
        "xcode-build-ios-simulator",
        "xcode-test-iphone-17-pro",
        "repository-quality-check",
        "repository-semantic-check",
        "architecture-fitness-check",
        "diff-check"
      ],
      "recommendedChecks": [],
      "humanReview": true
    },
    {
      "id": "xcode-project",
      "description": "Xcode project and scheme configuration changes.",
      "paths": [
        "Noma.xcodeproj/**"
      ],
      "requiredChecks": [
        "xcode-list",
        "xcode-build-ios-simulator",
        "repository-quality-check",
        "architecture-fitness-check",
        "diff-check"
      ],
      "recommendedChecks": [],
      "humanReview": true
    },
    {
      "id": "npm-tooling",
      "description": "Repository npm manifest, lockfile, or dependency ignore changes.",
      "paths": [
        "package.json",
        "package-lock.json",
        ".gitignore"
      ],
      "requiredChecks": [
        "npm-install",
        "repository-quality-check",
        "repository-semantic-check",
        "diff-check"
      ],
      "recommendedChecks": [],
      "humanReview": false
    },
    {
      "id": "naome-harness",
      "description": "NAOME harness, repository agent instructions, or NAOME documentation changes.",
      "paths": [
        ".naome/**",
        ".naomeignore",
        "AGENTS.md",
        "docs/naome/**"
      ],
      "requiredChecks": [
        "naome-harness-health",
        "repository-quality-check",
        "repository-semantic-check",
        "architecture-fitness-check",
        "diff-check"
      ],
      "recommendedChecks": [],
      "humanReview": false
    }
  ],
  "releaseGates": [
    {
      "checkId": "xcode-build-ios-simulator",
      "requiredWhen": "Before release or merge of app source, asset, test, or Xcode project changes."
    },
    {
      "checkId": "xcode-test-iphone-17-pro",
      "requiredWhen": "Before release or merge of OpenAI API, API usage, subscription, payment, premium entitlement, or test changes."
    },
    {
      "checkId": "naome-harness-health",
      "requiredWhen": "Before normal NAOME-routed work and before release or merge of harness changes."
    }
  ]
}
