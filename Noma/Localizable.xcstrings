    "create.project.add.description" : {
      "comment" : "Description text in the Add Project sheet explaining what projects are for.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Projekte helfen dir, Aufgaben über längere Zeiträume hinweg in Bereiche wie Privatleben, Arbeit oder Haushalt zu unterteilen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Projects help you organize tasks over longer periods by grouping them into areas such as personal life, work, or household."
