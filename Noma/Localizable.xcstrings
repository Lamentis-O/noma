    "create.projects.unlock-more.message" : {
      "comment" : "Informational text shown above the unlock button when the free project limit is reached.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Im Free-Tier kannst du bis zu 3 Projekte erstellen. Mit Pro kannst du unbegrenzt viele Projekte nutzen, um deine Aufgaben noch besser zu organisieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The Free tier lets you create up to 3 projects. With Pro, you can use unlimited projects to organize your tasks more effectively."
