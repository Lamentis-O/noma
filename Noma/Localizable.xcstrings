    "create.project.empty.subtitle" : {
      "comment" : "Subtitle in the empty project sheet explaining what projects are.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Projekte sind eigene Bereiche, um Arbeit, persönliche Ziele oder alles andere zu planen, das du getrennt halten möchtest."
